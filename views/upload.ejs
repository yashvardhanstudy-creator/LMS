<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Upload Notes</title>
    <link rel="stylesheet" href="/styles.css">
</head>

<body class="standard-body">
    <div class="upload-container">
        <div class="header-actions">
            <a href="/">&larr; View Student Portal</a>
            <% if (typeof role !=='undefined' && role==='admin' ) { %>
                <a href="/admin" style="color: #f39c12; font-weight: bold;">Admin Dashboard</a>
                <% } %>
                    <a href="/logout" style="color: #e74c3c;">Logout</a>
        </div>

        <h2>Upload a New Note</h2>

        <% if (typeof message !=='undefined' && message) { %>
            <div class="message">
                <%= message %>
            </div>
            <% } %>

                <form action="/upload" method="POST" enctype="multipart/form-data">
                    <label>Course </label>
                    <input type="text" placeholder="Computer Science & Engineering" name="course" list="course-list"
                        required>
                    <datalist id="course-list">
                        <% if (typeof existingCourses !=='undefined' ) { %>
                            <% existingCourses.forEach(course=> { %>
                                <option value="<%= course %>"></option>
                                <% }); %>
                                    <% } %>
                    </datalist>

                    <label>Semester</label>
                    <input type="number" name="semester" required>

                    <label>Subject</label>
                    <input type="text" placeholder="Data Structures" name="subject" list="subject-list" required>
                    <datalist id="subject-list">
                        <% if (typeof existingSubjects !=='undefined' ) { %>
                            <% existingSubjects.forEach(subject=> { %>
                                <option value="<%= subject %>"></option>
                                <% }); %>
                                    <% } %>
                    </datalist>

                    <label>Select PDF File:</label>
                    <input type="file" name="note_file" accept=".pdf" required>

                    <button type="submit">Upload Document</button>
                </form>

                <hr style="margin: 40px 0 20px; border: none; border-top: 1px solid #eee;">
                <h2>Manage Uploaded Notes</h2>

                <% if (typeof notes !=='undefined' && notes.length> 0) { %>
                    <ul class="manage-notes-list">
                        <% notes.forEach(note=> { %>
                            <li>
                                <div class="note-info">
                                    <strong>
                                        <%= note.course %>
                                    </strong> &gt; Sem <%= note.semester %> &gt; <%= note.subject %><br>
                                            <span class="filename">
                                                <%= note.original_filename %>
                                            </span>
                                </div>
                                <form action="/delete/<%= note.id %>" method="POST"
                                    onsubmit="return confirm('Are you sure you want to delete this note? This action cannot be undone.');">
                                    <button type="submit" class="delete-btn">Delete</button>
                                </form>
                            </li>
                            <% }); %>
                    </ul>
                    <% } else { %>
                        <p>No notes uploaded yet.</p>
                        <% } %>
    </div>
</body>

</html>